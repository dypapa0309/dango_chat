# 공통
SITE_URL=http://localhost:8888
ADMIN_TOKEN=CHANGE_ME
AUTO_REASSIGN_MINUTES=10
DISPATCH_MAX_ATTEMPTS=3

# Supabase (신규 키 체계 우선 / 레거시도 지원)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxx
# 아래 2개는 레거시 프로젝트일 때만 사용
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Toss Payments
# 결제창은 API 개별 연동 키(클라이언트 키 + 시크릿 키) 세트를 사용
TOSS_CLIENT_KEY=test_ck_xxxxxxxxxxxxxxxxx
TOSS_SECRET_KEY=test_sk_xxxxxxxxxxxxxxxxx
# 결제위젯 키를 쓸 경우 아래 변수명도 같이 지원
TOSS_WIDGET_CLIENT_KEY=
TOSS_WIDGET_SECRET_KEY=

# SOLAPI (없으면 mock 발송)
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SENDER_PHONE=01000000000
